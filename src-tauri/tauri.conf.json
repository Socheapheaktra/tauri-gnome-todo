{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GNOME Tauri TODO",
  "version": "0.1.0",
  "identifier": "dev.yeeahnis.gnome-tauri-todo",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tasks",
        "width": 1000,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "publisher": "Yeeahnis",
    "homepage": "https://github.com/yeeahnis/gnome-tauri-todo",
    "icon": ["icons/icon.png"],
    "copyright": "Copyright © 2026 Yeeahnis",
    "category": "Productivity",
    "shortDescription": "GNOME-inspired desktop task manager.",
    "longDescription": "GNOME Tauri TODO is a Linux-first desktop task manager for organizing projects, smart task views, search, and personal task workflows.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "section": "utils",
        "priority": "optional",
        "desktopTemplate": "linux/gnome-tauri-todo.desktop.in"
      },
      "rpm": {
        "release": "1",
        "epoch": 0,
        "desktopTemplate": "linux/gnome-tauri-todo.desktop.in"
      }
    }
  }
}
